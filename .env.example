# Backend (URL e chave pública — nunca commitar valores reais)
VITE_API_URL=https://seu-backend.exemplo.com
VITE_API_ANON_KEY=sua-chave-publica

# App
VITE_APP_NAME=Torres Vistoria
VITE_APP_URL=http://localhost:5173
# Exibe atalhos de login demo na tela de entrada (false em produção)
VITE_DEMO_MODE=true

# CLI / migrations (somente local ou CI — não usar no frontend)
# DB_PROJECT_ID=seu-project-id
# DB_ACCESS_TOKEN=seu-token-de-acesso

# Edge Functions (secrets do servidor — não expor no frontend)
# SITE_URL=https://seu-dominio.exemplo.com
# ALLOWED_ORIGINS=https://seu-dominio.exemplo.com,https://staging.exemplo.com
